//-----------------------------------------------------------------------------
// Title   : Mini Kraken FPGA Top
// Description: PULPissimo SoC + PULP Cluster on Nexys A7 FPGA
//-----------------------------------------------------------------------------
`include "pulp_soc_defines.sv"

module mini_kraken_top #(
  parameter int unsigned CORE_TYPE  = 0,
  parameter bit          USE_XPULP  = 1,
  parameter bit          USE_FPU    = 0,
  parameter bit          USE_ZFINX  = 1,
  parameter bit          USE_HWPE   = 0,
  parameter int unsigned NB_CORES   = 8  // Number of cores in the cluster
)(
  // FPGA board clock
  input  wire        sys_clk,
  // Active-low reset
  input  wire        pad_reset_n,

  // JTAG
  inout  wire        pad_jtag_tck,
  inout  wire        pad_jtag_tdi,
  input  wire        pad_jtag_tdo,
  inout  wire        pad_jtag_tms,

  // UART
  inout  wire        pad_uart_rx,
  inout  wire        pad_uart_tx,

  // SPI
  inout  wire        pad_spim_sdio0,
  inout  wire        pad_spim_sdio1,
  inout  wire        pad_spim_sdio2,
  inout  wire        pad_spim_sdio3,
  inout  wire        pad_spim_csn0,
  inout  wire        pad_spim_sck,

  // LEDs and switches for debug
  inout  wire        led0_o,
  inout  wire        led1_o,
  inout  wire        led2_o,
  inout  wire        led3_o,
  inout  wire        switch0_i,
  inout  wire        switch1_i,
  inout  wire        btnc_i,

  // SDIO
  inout  wire        sdio_reset_o,
  inout  wire        pad_sdio_clk,
  inout  wire        pad_sdio_cmd,
  inout  wire        pad_sdio_data0,
  inout  wire        pad_sdio_data1,
  inout  wire        pad_sdio_data2,
  inout  wire        pad_sdio_data3,

  // I2C
  inout  wire        pad_i2c0_sda,
  inout  wire        pad_i2c0_scl
);

  // ========================================================================
  // Parameters derived from your Vivado port discovery
  // ========================================================================
  // CDC FIFO depth (log2) — matches soc_domain.sv line 118
  localparam CDC_FIFOS_LOG_DEPTH = 3;
  // AXI parameters — matches soc_domain.sv lines 113-117
  localparam AXI_ADDR_WIDTH     = 32;
  localparam AXI_DATA_IN_WIDTH  = 64;  // Cluster→SoC data width
  localparam AXI_DATA_OUT_WIDTH = 32;  // SoC→Cluster data width
  localparam AXI_ID_IN_WIDTH    = 6;
  localparam AXI_USER_WIDTH     = 6;
  localparam EVNT_WIDTH         = 8;

  // Derived CDC buffer dimensions (2^CDC_FIFOS_LOG_DEPTH = 8 entries)
  localparam CDC_DEPTH = 2**CDC_FIFOS_LOG_DEPTH; // = 8

  // Per-channel data widths discovered from Vivado (total / CDC_DEPTH):
  // Slave (Cluster→SoC) interface:
  //   AW: 632/8 = 79 bits per entry
  //   AR: 584/8 = 73 bits per entry
  //   W:  632/8 = 79 bits per entry
  //   R:  632/8 = 79 bits per entry (SoC→Cluster)
  //   B:  112/8 = 14 bits per entry (SoC→Cluster)
  // Master (SoC→Cluster) interface:
  //   AW: 624/8 = 78 bits per entry
  //   AR: 576/8 = 72 bits per entry
  //   W:  344/8 = 43 bits per entry
  //   R:  368/8 = 46 bits per entry (Cluster→SoC)
  //   B:  104/8 = 13 bits per entry (Cluster→SoC)

  // ========================================================================
  // Clock and Reset Generation
  // ========================================================================
  logic soc_clk, per_clk, slow_clk, cluster_clk;
  logic soc_rstn, per_rstn, slow_clk_rstn, cluster_rstn;
  logic s_locked;
  logic rst_n;

  // Synchronize external reset
  assign rst_n = pad_reset_n;

  // Xilinx clock manager — generates soc_clk and per_clk from sys_clk
  xilinx_clk_mngr i_clk_manager (
    .resetn   ( rst_n   ),
    .clk_in1  ( sys_clk ),
    .clk_out1 ( soc_clk ),
    .clk_out2 ( per_clk ),
    .locked   ( s_locked )
  );

  // Slow clock generation (32.768 kHz from sys_clk)
  fpga_slow_clk_gen i_slow_clk_gen (
    .ref_clk_i  ( sys_clk  ),
    .rst_ni     ( rst_n     ),
    .slow_clk_o ( slow_clk  )
  );

  // Cluster clock — for now, same as soc_clk
  // (You can add a separate PLL output for the cluster later)
  assign cluster_clk = soc_clk;

  // Reset synchronizers
  rstgen i_soc_rstgen (
    .clk_i       ( soc_clk  ),
    .rst_ni      ( s_locked & rst_n ),
    .test_mode_i ( 1'b0     ),
    .rst_no      ( soc_rstn ),
    .init_no     (          )
  );

  rstgen i_per_rstgen (
    .clk_i       ( per_clk  ),
    .rst_ni      ( s_locked & rst_n ),
    .test_mode_i ( 1'b0     ),
    .rst_no      ( per_rstn ),
    .init_no     (          )
  );

  rstgen i_slow_rstgen (
    .clk_i       ( slow_clk      ),
    .rst_ni      ( s_locked & rst_n ),
    .test_mode_i ( 1'b0          ),
    .rst_no      ( slow_clk_rstn ),
    .init_no     (               )
  );

  rstgen i_cluster_rstgen (
    .clk_i       ( cluster_clk  ),
    .rst_ni      ( s_locked & rst_n ),
    .test_mode_i ( 1'b0        ),
    .rst_no      ( cluster_rstn ),
    .init_no     (              )
  );

  // ========================================================================
  // Async CDC Wires between pulp_soc and pulp_cluster
  // ========================================================================

  // --- Slave port (Cluster → SoC) ---
  logic [CDC_DEPTH-1:0][78:0]  async_data_slave_aw_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_aw_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_aw_rptr;

  logic [CDC_DEPTH-1:0][72:0]  async_data_slave_ar_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_ar_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_ar_rptr;

  logic [CDC_DEPTH-1:0][78:0]  async_data_slave_w_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_w_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_w_rptr;

  logic [CDC_DEPTH-1:0][78:0]  async_data_slave_r_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_r_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_r_rptr;

  logic [CDC_DEPTH-1:0][13:0]  async_data_slave_b_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_b_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_slave_b_rptr;

  // --- Master port (SoC → Cluster) ---
  logic [CDC_DEPTH-1:0][77:0]  async_data_master_aw_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_aw_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_aw_rptr;

  logic [CDC_DEPTH-1:0][71:0]  async_data_master_ar_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_ar_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_ar_rptr;

  logic [CDC_DEPTH-1:0][42:0]  async_data_master_w_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_w_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_w_rptr;

  logic [CDC_DEPTH-1:0][45:0]  async_data_master_r_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_r_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_r_rptr;

  logic [CDC_DEPTH-1:0][12:0]  async_data_master_b_data;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_b_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0] async_data_master_b_rptr;

  // --- Cluster Events ---
  logic [CDC_DEPTH-1:0][EVNT_WIDTH-1:0] async_cluster_events_data;
  logic [CDC_FIFOS_LOG_DEPTH:0]          async_cluster_events_wptr;
  logic [CDC_FIFOS_LOG_DEPTH:0]          async_cluster_events_rptr;

  // --- Cluster control signals ---
  logic        cluster_busy;
  logic        cluster_rstn_req;
  logic [NB_CORES-1:0] cluster_dbg_irq_valid;
  logic        dma_pe_evt_ack, dma_pe_evt_valid;
  logic        dma_pe_irq_ack, dma_pe_irq_valid;
  logic        pf_evt_ack, pf_evt_valid;

  // ========================================================================
  // Peripheral signal wires
  // ========================================================================
  logic [3:0] s_timer_ch0, s_timer_ch1, s_timer_ch2, s_timer_ch3;

  localparam NGPIO = gpio_reg_pkg::GPIOCount;
  logic [NGPIO-1:0] s_gpio_in, s_gpio_out, s_gpio_tx_en;

  uart_pkg::uart_to_pad_t [udma_cfg_pkg::N_UART-1:0] s_uart_to_pad;
  uart_pkg::pad_to_uart_t [udma_cfg_pkg::N_UART-1:0] s_pad_to_uart;
  i2c_pkg::i2c_to_pad_t   [udma_cfg_pkg::N_I2C-1:0]  s_i2c_to_pad;
  i2c_pkg::pad_to_i2c_t   [udma_cfg_pkg::N_I2C-1:0]  s_pad_to_i2c;
  sdio_pkg::sdio_to_pad_t  [udma_cfg_pkg::N_SDIO-1:0] s_sdio_to_pad;
  sdio_pkg::pad_to_sdio_t  [udma_cfg_pkg::N_SDIO-1:0] s_pad_to_sdio;
  i2s_pkg::i2s_to_pad_t   [udma_cfg_pkg::N_I2S-1:0]  s_i2s_to_pad;
  i2s_pkg::pad_to_i2s_t   [udma_cfg_pkg::N_I2S-1:0]  s_pad_to_i2s;
  qspi_pkg::qspi_to_pad_t [udma_cfg_pkg::N_QSPIM-1:0] s_qspi_to_pad;
  qspi_pkg::pad_to_qspi_t [udma_cfg_pkg::N_QSPIM-1:0] s_pad_to_qspi;
  cpi_pkg::pad_to_cpi_t   [udma_cfg_pkg::N_CPI-1:0]  s_pad_to_cpi;
  hyper_pkg::hyper_to_pad_t [udma_cfg_pkg::N_HYPER-1:0] s_hyper_to_pad;
  hyper_pkg::pad_to_hyper_t [udma_cfg_pkg::N_HYPER-1:0] s_pad_to_hyper;

  // APB chip control — leave unconnected (or add register file later)
  logic        s_apb_pready;
  logic [31:0] s_apb_prdata;
  logic        s_apb_pslverr;

  // Tie APB slave responses
  assign s_apb_pready  = 1'b1;
  assign s_apb_prdata  = 32'h0;
  assign s_apb_pslverr = 1'b0;

  // JTAG signals
  logic s_jtag_tck, s_jtag_tdi, s_jtag_tdo, s_jtag_tms, s_jtag_trstn;
  logic s_jtag_bypass_fll;

  // ========================================================================
  // PULP SoC Instance
  // ========================================================================
  pulp_soc #(
    .CORE_TYPE           ( CORE_TYPE         ),
    .USE_XPULP           ( USE_XPULP         ),
    .USE_FPU             ( USE_FPU           ),
    .USE_HWPE            ( USE_HWPE          ),
    .SIM_STDOUT          ( 0                 ),
    .USE_ZFINX           ( USE_ZFINX         ),
    .AXI_ADDR_WIDTH      ( AXI_ADDR_WIDTH    ),
    .AXI_DATA_IN_WIDTH   ( AXI_DATA_IN_WIDTH ),
    .AXI_DATA_OUT_WIDTH  ( AXI_DATA_OUT_WIDTH),
    .AXI_ID_IN_WIDTH     ( AXI_ID_IN_WIDTH   ),
    .AXI_USER_WIDTH      ( AXI_USER_WIDTH    ),
    .CDC_FIFOS_LOG_DEPTH ( CDC_FIFOS_LOG_DEPTH ),
    .EVNT_WIDTH          ( EVNT_WIDTH        ),
    .NB_CORES            ( NB_CORES          )
  ) i_pulp_soc (
    // Clocks and resets
    .slow_clk_i                  ( slow_clk      ),
    .slow_clk_rstn_synced_i      ( slow_clk_rstn ),
    .soc_clk_i                   ( soc_clk       ),
    .soc_rstn_synced_i           ( soc_rstn      ),
    .per_clk_i                   ( per_clk       ),
    .per_rstn_synced_i           ( per_rstn      ),
    .soc_cluster_cdc_rst_ni      ( soc_rstn      ),
    .dft_test_mode_i             ( 1'b0          ),
    .dft_cg_enable_i             ( 1'b0          ),
    .bootsel_i                   ( 2'b00         ),
    .fc_fetch_en_valid_i         ( 1'b1          ),
    .fc_fetch_en_i               ( 1'b1          ),

    // ---- Cluster CDC: Slave port (Cluster → SoC) ----
    .async_data_slave_aw_wptr_i  ( async_data_slave_aw_wptr ),
    .async_data_slave_aw_data_i  ( async_data_slave_aw_data ),
    .async_data_slave_aw_rptr_o  ( async_data_slave_aw_rptr ),
    .async_data_slave_ar_wptr_i  ( async_data_slave_ar_wptr ),
    .async_data_slave_ar_data_i  ( async_data_slave_ar_data ),
    .async_data_slave_ar_rptr_o  ( async_data_slave_ar_rptr ),
    .async_data_slave_w_wptr_i   ( async_data_slave_w_wptr  ),
    .async_data_slave_w_data_i   ( async_data_slave_w_data  ),
    .async_data_slave_w_rptr_o   ( async_data_slave_w_rptr  ),
    .async_data_slave_r_wptr_o   ( async_data_slave_r_wptr  ),
    .async_data_slave_r_data_o   ( async_data_slave_r_data  ),
    .async_data_slave_r_rptr_i   ( async_data_slave_r_rptr  ),
    .async_data_slave_b_wptr_o   ( async_data_slave_b_wptr  ),
    .async_data_slave_b_data_o   ( async_data_slave_b_data  ),
    .async_data_slave_b_rptr_i   ( async_data_slave_b_rptr  ),

    // ---- Cluster CDC: Master port (SoC → Cluster) ----
    .async_data_master_aw_wptr_o ( async_data_master_aw_wptr ),
    .async_data_master_aw_data_o ( async_data_master_aw_data ),
    .async_data_master_aw_rptr_i ( async_data_master_aw_rptr ),
    .async_data_master_ar_wptr_o ( async_data_master_ar_wptr ),
    .async_data_master_ar_data_o ( async_data_master_ar_data ),
    .async_data_master_ar_rptr_i ( async_data_master_ar_rptr ),
    .async_data_master_w_wptr_o  ( async_data_master_w_wptr  ),
    .async_data_master_w_data_o  ( async_data_master_w_data  ),
    .async_data_master_w_rptr_i  ( async_data_master_w_rptr  ),
    .async_data_master_r_wptr_i  ( async_data_master_r_wptr  ),
    .async_data_master_r_data_i  ( async_data_master_r_data  ),
    .async_data_master_r_rptr_o  ( async_data_master_r_rptr  ),
    .async_data_master_b_wptr_i  ( async_data_master_b_wptr  ),
    .async_data_master_b_data_i  ( async_data_master_b_data  ),
    .async_data_master_b_rptr_o  ( async_data_master_b_rptr  ),

    // ---- Cluster events and control ----
    .async_cluster_events_wptr_o ( async_cluster_events_wptr ),
    .async_cluster_events_rptr_i ( async_cluster_events_rptr ),
    .async_cluster_events_data_o ( async_cluster_events_data ),
    .cluster_busy_i              ( cluster_busy              ),
    .cluster_rstn_req_o          ( cluster_rstn_req          ),
    .cluster_dbg_irq_valid_o     ( cluster_dbg_irq_valid     ),
    .dma_pe_evt_ack_o            ( dma_pe_evt_ack            ),
    .dma_pe_evt_valid_i          ( dma_pe_evt_valid          ),
    .dma_pe_irq_ack_o            ( dma_pe_irq_ack            ),
    .dma_pe_irq_valid_i          ( dma_pe_irq_valid          ),
    .pf_evt_ack_o                ( pf_evt_ack                ),
    .pf_evt_valid_i              ( pf_evt_valid              ),

    // ---- Peripherals ----
    .timer_ch0_o                 ( s_timer_ch0     ),
    .timer_ch1_o                 ( s_timer_ch1     ),
    .timer_ch2_o                 ( s_timer_ch2     ),
    .timer_ch3_o                 ( s_timer_ch3     ),
    .uart_to_pad_o               ( s_uart_to_pad   ),
    .pad_to_uart_i               ( s_pad_to_uart   ),
    .i2c_to_pad_o                ( s_i2c_to_pad    ),
    .pad_to_i2c_i                ( s_pad_to_i2c    ),
    .sdio_to_pad_o               ( s_sdio_to_pad   ),
    .pad_to_sdio_i               ( s_pad_to_sdio   ),
    .i2s_to_pad_o                ( s_i2s_to_pad    ),
    .pad_to_i2s_i                ( s_pad_to_i2s    ),
    .qspi_to_pad_o               ( s_qspi_to_pad   ),
    .pad_to_qspi_i               ( s_pad_to_qspi   ),
    .pad_to_cpi_i                ( s_pad_to_cpi    ),
    .hyper_to_pad_o              ( s_hyper_to_pad   ),
    .pad_to_hyper_i              ( s_pad_to_hyper   ),
    .gpio_i                      ( s_gpio_in       ),
    .gpio_o                      ( s_gpio_out      ),
    .gpio_tx_en_o                ( s_gpio_tx_en    ),

    // ---- JTAG ----
    .jtag_tck_i                  ( s_jtag_tck      ),
    .jtag_trst_ni                ( s_jtag_trstn    ),
    .jtag_tms_i                  ( s_jtag_tms      ),
    .jtag_tdi_i                  ( s_jtag_tdi      ),
    .jtag_tdo_o                  ( s_jtag_tdo      ),
    .jtag_tap_bypass_fll_clk_o   ( s_jtag_bypass_fll ),

    // ---- APB chip control ----
    .apb_chip_ctrl_master_paddr_o   (  ),
    .apb_chip_ctrl_master_pwdata_o  (  ),
    .apb_chip_ctrl_master_pwrite_o  (  ),
    .apb_chip_ctrl_master_psel_o    (  ),
    .apb_chip_ctrl_master_penable_o (  ),
    .apb_chip_ctrl_master_prdata_i  ( s_apb_prdata  ),
    .apb_chip_ctrl_master_pready_i  ( s_apb_pready  ),
    .apb_chip_ctrl_master_pslverr_i ( s_apb_pslverr ),
    .apb_chip_ctrl_master_pprot_o   (  ),
    .apb_chip_ctrl_master_pstrb_o   (  )
  );

  // ========================================================================
  // PULP Cluster Instance
  // ========================================================================
  // TODO: Instantiate pulp_cluster here and connect the async CDC wires.
  //
  // You need to use pulp_cluster_wrap.sv (from your imports/cluster_rtl/)
  // which already has the async CDC interface matching pulp_soc's ports.
  //
  // The connection pattern is:
  //   pulp_soc async_data_slave_*  ←→  cluster's SoC-facing AXI master
  //   pulp_soc async_data_master_* ←→  cluster's SoC-facing AXI slave
  //
  // Example (fill in actual port names from pulp_cluster_wrap.sv):
  //
  // pulp_cluster_wrap #(
  //   .NB_CORES          ( NB_CORES          ),
  //   .AXI_ADDR_WIDTH    ( AXI_ADDR_WIDTH    ),
  //   ... // match other parameters
  // ) i_cluster (
  //   .clk_i             ( cluster_clk       ),
  //   .rst_ni            ( cluster_rstn & cluster_rstn_req ),
  //   .ref_clk_i         ( slow_clk          ),
  //   .test_mode_i       ( 1'b0              ),
  //   // Connect async CDC buses (names depend on pulp_cluster_wrap ports)
  //   .async_data_slave_aw_data_o  ( async_data_slave_aw_data ),
  //   .async_data_slave_aw_wptr_o  ( async_data_slave_aw_wptr ),
  //   .async_data_slave_aw_rptr_i  ( async_data_slave_aw_rptr ),
  //   ... etc ...
  //   // Cluster events
  //   .async_cluster_events_rptr_o ( async_cluster_events_rptr ),
  //   .async_cluster_events_wptr_i ( async_cluster_events_wptr ),
  //   .async_cluster_events_data_i ( async_cluster_events_data ),
  //   // Cluster control
  //   .cluster_busy_o              ( cluster_busy              ),
  //   .dbg_irq_valid_i             ( cluster_dbg_irq_valid     ),
  //   .dma_pe_evt_valid_o          ( dma_pe_evt_valid          ),
  //   .dma_pe_evt_ack_i            ( dma_pe_evt_ack            ),
  //   .dma_pe_irq_valid_o          ( dma_pe_irq_valid          ),
  //   .dma_pe_irq_ack_i            ( dma_pe_irq_ack            ),
  //   .pf_evt_valid_o              ( pf_evt_valid              ),
  //   .pf_evt_ack_i                ( pf_evt_ack                )
  // );

  // TEMPORARY: Tie off cluster signals until cluster is integrated
  assign cluster_busy       = 1'b0;
  assign dma_pe_evt_valid   = 1'b0;
  assign dma_pe_irq_valid   = 1'b0;
  assign pf_evt_valid       = 1'b0;
  assign async_data_slave_aw_wptr = '0;
  assign async_data_slave_aw_data = '0;
  assign async_data_slave_ar_wptr = '0;
  assign async_data_slave_ar_data = '0;
  assign async_data_slave_w_wptr  = '0;
  assign async_data_slave_w_data  = '0;
  assign async_data_slave_r_rptr  = '0;
  assign async_data_slave_b_rptr  = '0;
  assign async_data_master_aw_rptr = '0;
  assign async_data_master_ar_rptr = '0;
  assign async_data_master_w_rptr  = '0;
  assign async_data_master_r_wptr  = '0;
  assign async_data_master_r_data  = '0;
  assign async_data_master_b_wptr  = '0;
  assign async_data_master_b_data  = '0;
  assign async_cluster_events_rptr = '0;

  // ========================================================================
  // FPGA Pad Connections (same pattern as xilinx_pulpissimo.v)
  // ========================================================================

  // JTAG pads
  assign s_jtag_tck   = pad_jtag_tck;
  assign s_jtag_tdi   = pad_jtag_tdi;
  assign s_jtag_tms   = pad_jtag_tms;
  assign s_jtag_trstn = rst_n;  // Use board reset as JTAG reset

  // UART — directly connect (no pad mux on FPGA)
  assign s_pad_to_uart[0].rx_i = pad_uart_rx;
  assign pad_uart_tx = s_uart_to_pad[0].tx_o;

  // SPI
  // Use IOBUF for bidirectional SPI data lines
  // (Simplified — you may need proper IOBUF instantiation)
  assign s_pad_to_qspi[0].sd0_i = pad_spim_sdio0;
  assign s_pad_to_qspi[0].sd1_i = pad_spim_sdio1;
  assign s_pad_to_qspi[0].sd2_i = pad_spim_sdio2;
  assign s_pad_to_qspi[0].sd3_i = pad_spim_sdio3;

  // I2C
  assign s_pad_to_i2c[0].scl_i = pad_i2c0_scl;
  assign s_pad_to_i2c[0].sda_i = pad_i2c0_sda;

  // GPIO — directly wire LEDs/switches
  assign s_gpio_in = '0; // Connect actual GPIO pads as needed
  assign led0_o = s_gpio_out[0];
  assign led1_o = s_gpio_out[1];
  assign led2_o = s_gpio_out[2];
  assign led3_o = s_gpio_out[3];

  // Tie unused peripheral inputs
  assign s_pad_to_cpi   = '0;
  assign s_pad_to_hyper  = '0;
  assign s_pad_to_sdio   = '0;
  assign s_pad_to_i2s    = '0;

endmodule

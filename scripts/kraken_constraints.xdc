# Kraken SoC Constraints File
# Maps internal debug signals to FPGA I/O pins (Artix-7 xc7a100tcsg324-1)

# Clock and Reset
set_property PACKAGE_PIN E3 [get_ports clk_i]
set_property IOSTANDARD LVCMOS33 [get_ports clk_i]
set_property PULLDOWN true [get_ports clk_i]

set_property PACKAGE_PIN D9 [get_ports rst_ni]
set_property IOSTANDARD LVCMOS33 [get_ports rst_ni]
set_property PULLUP true [get_ports rst_ni]

set_property PACKAGE_PIN A9 [get_ports test_en_i]
set_property IOSTANDARD LVCMOS33 [get_ports test_en_i]

# Core 0 Debug Outputs
set_property PACKAGE_PIN T10 [get_ports {core_0_addr_o[0]}]
set_property PACKAGE_PIN T9 [get_ports {core_0_addr_o[1]}]
set_property PACKAGE_PIN J5 [get_ports {core_0_addr_o[2]}]
set_property PACKAGE_PIN H5 [get_ports {core_0_addr_o[3]}]
set_property PACKAGE_PIN K5 [get_ports {core_0_addr_o[4]}]
set_property PACKAGE_PIN K6 [get_ports {core_0_addr_o[5]}]
set_property PACKAGE_PIN P7 [get_ports {core_0_addr_o[6]}]
set_property PACKAGE_PIN P8 [get_ports {core_0_addr_o[7]}]
set_property PACKAGE_PIN P9 [get_ports {core_0_addr_o[8]}]
set_property PACKAGE_PIN N9 [get_ports {core_0_addr_o[9]}]
set_property PACKAGE_PIN M8 [get_ports {core_0_addr_o[10]}]
set_property PACKAGE_PIN L8 [get_ports {core_0_addr_o[11]}]
set_property PACKAGE_PIN M9 [get_ports {core_0_addr_o[12]}]
set_property PACKAGE_PIN L9 [get_ports {core_0_addr_o[13]}]
set_property PACKAGE_PIN M10 [get_ports {core_0_addr_o[14]}]
set_property PACKAGE_PIN L10 [get_ports {core_0_addr_o[15]}]
set_property PACKAGE_PIN N8 [get_ports {core_0_addr_o[16]}]
set_property PACKAGE_PIN M11 [get_ports {core_0_addr_o[17]}]
set_property PACKAGE_PIN L11 [get_ports {core_0_addr_o[18]}]
set_property PACKAGE_PIN K11 [get_ports {core_0_addr_o[19]}]
set_property PACKAGE_PIN K9 [get_ports {core_0_addr_o[20]}]
set_property PACKAGE_PIN J9 [get_ports {core_0_addr_o[21]}]
set_property PACKAGE_PIN J8 [get_ports {core_0_addr_o[22]}]
set_property PACKAGE_PIN G8 [get_ports {core_0_addr_o[23]}]
set_property PACKAGE_PIN G7 [get_ports {core_0_addr_o[24]}]
set_property PACKAGE_PIN H6 [get_ports {core_0_addr_o[25]}]
set_property PACKAGE_PIN H4 [get_ports {core_0_addr_o[26]}]
set_property PACKAGE_PIN H3 [get_ports {core_0_addr_o[27]}]
set_property PACKAGE_PIN H2 [get_ports {core_0_addr_o[28]}]
set_property PACKAGE_PIN H1 [get_ports {core_0_addr_o[29]}]
set_property PACKAGE_PIN G4 [get_ports {core_0_addr_o[30]}]
set_property PACKAGE_PIN G3 [get_ports {core_0_addr_o[31]}]

# Core 0 Data Output (32 bits)
set_property PACKAGE_PIN B4 [get_ports {core_0_data_o[0]}]
set_property PACKAGE_PIN B5 [get_ports {core_0_data_o[1]}]
set_property PACKAGE_PIN A4 [get_ports {core_0_data_o[2]}]
set_property PACKAGE_PIN A5 [get_ports {core_0_data_o[3]}]
set_property PACKAGE_PIN C5 [get_ports {core_0_data_o[4]}]

set_property PACKAGE_PIN E5 [get_ports {core_0_data_o[30]}]
set_property PACKAGE_PIN D5 [get_ports {core_0_data_o[31]}]

# Core 0 Request signal
set_property PACKAGE_PIN E8 [get_ports core_0_req_o]
set_property IOSTANDARD LVCMOS33 [get_ports core_0_req_o]

# Memory Valid signal
set_property PACKAGE_PIN E7 [get_ports mem_valid_o]
set_property IOSTANDARD LVCMOS33 [get_ports mem_valid_o]

# Memory Data Output (32 bits)
set_property PACKAGE_PIN E4 [get_ports {mem_data_o[0]}]
set_property PACKAGE_PIN D4 [get_ports {mem_data_o[1]}]
set_property PACKAGE_PIN E2 [get_ports {mem_data_o[2]}]
set_property PACKAGE_PIN D3 [get_ports {mem_data_o[3]}]
set_property PACKAGE_PIN F5 [get_ports {mem_data_o[4]}]
set_property PACKAGE_PIN F4 [get_ports {mem_data_o[5]}]
set_property PACKAGE_PIN B2 [get_ports {mem_data_o[6]}]
set_property PACKAGE_PIN B1 [get_ports {mem_data_o[7]}]
set_property PACKAGE_PIN C2 [get_ports {mem_data_o[8]}]
set_property PACKAGE_PIN C1 [get_ports {mem_data_o[9]}]
set_property PACKAGE_PIN D2 [get_ports {mem_data_o[10]}]
set_property PACKAGE_PIN D1 [get_ports {mem_data_o[11]}]
set_property PACKAGE_PIN F2 [get_ports {mem_data_o[12]}]
set_property PACKAGE_PIN F1 [get_ports {mem_data_o[13]}]
set_property PACKAGE_PIN G2 [get_ports {mem_data_o[14]}]
set_property PACKAGE_PIN G1 [get_ports {mem_data_o[15]}]
set_property PACKAGE_PIN J2 [get_ports {mem_data_o[16]}]
set_property PACKAGE_PIN J1 [get_ports {mem_data_o[17]}]
set_property PACKAGE_PIN K2 [get_ports {mem_data_o[18]}]
set_property PACKAGE_PIN K1 [get_ports {mem_data_o[19]}]
set_property PACKAGE_PIN L4 [get_ports {mem_data_o[20]}]
set_property PACKAGE_PIN L3 [get_ports {mem_data_o[21]}]
set_property PACKAGE_PIN L2 [get_ports {mem_data_o[22]}]
set_property PACKAGE_PIN L1 [get_ports {mem_data_o[23]}]
set_property PACKAGE_PIN M4 [get_ports {mem_data_o[24]}]
set_property PACKAGE_PIN M3 [get_ports {mem_data_o[25]}]
set_property PACKAGE_PIN M2 [get_ports {mem_data_o[26]}]
set_property PACKAGE_PIN M1 [get_ports {mem_data_o[27]}]
set_property PACKAGE_PIN N4 [get_ports {mem_data_o[28]}]
set_property PACKAGE_PIN N3 [get_ports {mem_data_o[29]}]
set_property PACKAGE_PIN N2 [get_ports {mem_data_o[30]}]
set_property PACKAGE_PIN N1 [get_ports {mem_data_o[31]}]

# Set all outputs to LVCMOS33
set_property IOSTANDARD LVCMOS33 [get_ports core_0_addr_o*]
set_property IOSTANDARD LVCMOS33 [get_ports core_0_data_o*]
set_property IOSTANDARD LVCMOS33 [get_ports mem_data_o*]

# Set I/O slew rate and drive strength
set_property SLEW SLOW [get_ports core_0_addr_o*]
set_property DRIVE 4 [get_ports core_0_addr_o*]
set_property SLEW SLOW [get_ports core_0_data_o*]
set_property DRIVE 4 [get_ports core_0_data_o*]
set_property SLEW SLOW [get_ports mem_data_o*]
set_property DRIVE 4 [get_ports mem_data_o*]
